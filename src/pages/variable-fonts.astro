---
import Layout from '../layouts/Layout.astro';
import { font } from 'astro:font';

// Variable font with weight range
const inter = font({
	family: 'Inter Variable',
	source: 'google',
	weight: '100 900', // Full weight range
	variable: true,
});

// Variable font with multiple axes (if supported)
const recursive = font({
	family: 'Recursive',
	source: 'google',
	weight: '300 1000',
	variable: true,
});
---

<Layout title="Variable Fonts - Astro Font API">
	<main>
		<a href="/" class="back-link">← Back to Home</a>
		
		<h1>Variable Fonts Examples</h1>
		
		<section>
			<h2>What are Variable Fonts?</h2>
			<p>
				Variable fonts are a single font file that acts like multiple fonts.
				Instead of loading separate files for each weight, you get a continuous range.
				This reduces HTTP requests and gives you fine-grained control over typography.
			</p>
		</section>
		
		<section>
			<h2>Inter Variable (Weight Axis)</h2>
			<div class:list={[inter.class]}>
				<p style="font-weight: 100;">Weight 100 - Thin</p>
				<p style="font-weight: 200;">Weight 200 - Extra Light</p>
				<p style="font-weight: 300;">Weight 300 - Light</p>
				<p style="font-weight: 400;">Weight 400 - Regular</p>
				<p style="font-weight: 500;">Weight 500 - Medium</p>
				<p style="font-weight: 600;">Weight 600 - Semi Bold</p>
				<p style="font-weight: 700;">Weight 700 - Bold</p>
				<p style="font-weight: 800;">Weight 800 - Extra Bold</p>
				<p style="font-weight: 900;">Weight 900 - Black</p>
			</div>
		</section>
		
		<section>
			<h2>Fine-tuned Weights</h2>
			<p>Variable fonts let you use ANY weight value:</p>
			<div class:list={[inter.class]}>
				<p style="font-weight: 350;">Weight 350 - Between Light and Regular</p>
				<p style="font-weight: 450;">Weight 450 - Slightly heavier than Regular</p>
				<p style="font-weight: 550;">Weight 550 - Between Medium and Semi Bold</p>
				<p style="font-weight: 650;">Weight 650 - Custom emphasis</p>
			</div>
		</section>
		
		<section>
			<h2>Recursive (Multi-axis Variable Font)</h2>
			<p>
				Recursive supports multiple variation axes including weight,
				monospace/sans-serif blending, casual/linear style, and slant.
			</p>
			<div class:list={[recursive.class]}>
				<p style="font-weight: 300;">Recursive at weight 300</p>
				<p style="font-weight: 500;">Recursive at weight 500</p>
				<p style="font-weight: 700;">Recursive at weight 700</p>
				<p style="font-weight: 1000;">Recursive at weight 1000 (maximum!)</p>
			</div>
		</section>
		
		<section>
			<h2>Benefits of Variable Fonts</h2>
			<ul>
				<li>✅ Single file for multiple weights/styles</li>
				<li>✅ Reduced HTTP requests</li>
				<li>✅ Smaller total file size than loading multiple static fonts</li>
				<li>✅ Smooth animations between weights</li>
				<li>✅ Fine-tuned typography control</li>
				<li>✅ Better performance on slow connections</li>
			</ul>
		</section>
		
		<section>
			<h2>Usage Example</h2>
			<pre><code>import &#123; font &#125; from 'astro:font';

const variableFont = font(&#123;
  family: 'Inter Variable',
  source: 'google',
  weight: '100 900',  // Range, not array
  variable: true,      // Enable variable font
&#125;);

// Use any weight value:
&lt;p style="font-weight: 450;"&gt;Custom weight&lt;/p&gt;</code></pre>
		</section>
		
		<section class="demo">
			<h2>Interactive Weight Demo</h2>
			<p class:list={[inter.class]} id="weight-demo" style="font-weight: 400; font-size: 2rem;">
				The quick brown fox jumps over the lazy dog
			</p>
			<input 
				type="range" 
				min="100" 
				max="900" 
				value="400" 
				id="weight-slider"
			/>
			<p>Current weight: <span id="weight-value">400</span></p>
		</section>
	</main>
</Layout>

<script>
	const slider = document.getElementById('weight-slider') as HTMLInputElement;
	const demo = document.getElementById('weight-demo') as HTMLElement;
	const value = document.getElementById('weight-value') as HTMLElement;
	
	if (slider && demo && value) {
		slider.addEventListener('input', (e) => {
			const weight = (e.target as HTMLInputElement).value;
			demo.style.fontWeight = weight;
			value.textContent = weight;
		});
	}
</script>

<style>
	main {
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem;
	}
	
	.back-link {
		display: inline-block;
		margin-bottom: 2rem;
		color: #0066cc;
		text-decoration: none;
	}
	
	section {
		margin: 3rem 0;
		padding: 2rem;
		background: #f9f9f9;
		border-radius: 0.5rem;
	}
	
	section.demo {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
	}
	
	h1 {
		font-size: 2.5rem;
		margin-bottom: 2rem;
	}
	
	h2 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		color: #555;
	}
	
	section.demo h2 {
		color: white;
	}
	
	p {
		font-size: 1.125rem;
		line-height: 1.6;
		margin: 1rem 0;
	}
	
	ul {
		list-style-position: inside;
		line-height: 2;
	}
	
	li {
		margin: 0.5rem 0;
	}
	
	pre {
		background: #2d2d2d;
		color: #f8f8f2;
		padding: 1.5rem;
		border-radius: 0.5rem;
		overflow-x: auto;
		font-size: 0.875rem;
		line-height: 1.5;
	}
	
	code {
		font-family: 'Courier New', monospace;
	}
	
	input[type="range"] {
		width: 100%;
		margin: 2rem 0 1rem;
		height: 8px;
		background: rgba(255,255,255,0.3);
		border-radius: 5px;
		outline: none;
	}
	
	input[type="range"]::-webkit-slider-thumb {
		appearance: none;
		width: 20px;
		height: 20px;
		background: white;
		cursor: pointer;
		border-radius: 50%;
	}
	
	input[type="range"]::-moz-range-thumb {
		width: 20px;
		height: 20px;
		background: white;
		cursor: pointer;
		border-radius: 50%;
		border: none;
	}
</style>
